{
    "name": "hfcatv-activity-service",
    "version": "1.0.0",
    "description": "",
    "main": "dist/app.js",
    "scripts": {
        "watch-server": "nodemon --watch src -e ts,tsx --exec ts-node src/app.ts",
        "build-ts": "tsc",
        "copy-static-assets": "ts-node copyStaticAssets.ts",
        "tslint": "tslint -c tslint.json -p tsconfig.json",
        "serve": "node dist/app.js",
        "build": "npm run tslint && npm run build-ts && npm run copy-static-assets",
        "start": "npm run serve",
        "heroku-postbuild": "npm run build"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "koa": "^2.8.1",
        "koa-bodyparser": "^4.2.1",
        "koa-cors": "0.0.16",
        "koa-router": "^7.4.0",
        "sequelize": "^5.18.4"
    },
    "devDependencies": {
        "@types/bluebird": "^3.5.27",
        "@types/koa": "^2.0.49",
        "@types/koa-bodyparser": "^4.3.0",
        "@types/koa-cors": "0.0.0",
        "@types/koa-router": "^7.0.42",
        "@types/node": "^12.7.5",
        "@types/validator": "^10.11.3",
        "nodemon": "^1.19.2",
        "ts-node": "^8.4.1",
        "typescript": "^3.6.3"
    }
}
